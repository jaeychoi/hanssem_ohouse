      <div class="strategy-card" style="border-top-color:#374151"><h4>③ 침대+매트리스 번들 세트 기획</h4><p>침대 구매 고객 매트리스 별도 구매 패턴 분석. 침대+라텍스탑 번들 세트로 1회 구매 객단가 상승 및 교차 구매 유도. 네이버 채널 검증 데이터 활용</p></div>
      <div class="strategy-card" style="border-top-color:#374151"><h4>④ 밸런스 볼륨탑·스테디2 컴피 오집 진입</h4><p>네이버에서 검증된 밸런스 볼륨탑(+149%)·스테디2 컴피(+480%) 오집 신규 론칭 검토. 오집 매트리스 포트폴리오 다변화로 노뜨 컴포트 의존도 완화</p></div>
    </div>
  </section>

</main>

<script>
const months = ["25.06", "25.07", "25.08", "25.09", "25.10", "25.11", "25.12", "26.01", "26.02", "26.03", "26.04"];
const pbData  = [7.8693, 8.5983, 8.2442, 8.256, 6.9516, 7.7355, 10.8811, 9.415, 6.2334, 8.3452, 5.5549];
const epData  = [2.4681, 2.193, 3.0766, 3.7421, 3.8904, 3.3415, 4.2665, 4.0937, 3.4189, 4.364, 3.295];
const totData = [10.3374, 10.7913, 11.3208, 11.9981, 10.842, 11.077, 15.1476, 13.5087, 9.6523, 12.7092, 8.8499];
const yoyPB   = [89.6, 49.7, 45.9, 31.5, 21.4, 27.1, 39.2, 9.7, -24.0, -26.3, -41.3];
const yoyEP   = [-3.1, -22.9, 16.5, 75.5, 81.1, 48.4, 58.3, 39.3, -2.4, 41.2, 31.2];
const yoyTot  = [54.4, 25.6, 36.5, 42.6, 37.7, 32.8, 44.1, 17.2, -17.5, -11.8, -26.1];
const catNames26 = ["수납", "거실", "침실", "키즈", "주방", "서재"];
const catData26  = [10.1566, 5.3998, 5.3276, 4.0594, 2.685, 1.9201];
const catData25  = [11.7653, 6.4125, 5.3067, 5.2672, 5.5384, 3.2781];
const catShare26 = [34.4, 18.3, 18.0, 13.7, 9.1, 6.5];
const catShare25 = [31.3, 17.1, 14.1, 14.0, 14.7, 8.7];
const catColors  = ["#374151", "#4b5563", "#6b7280", "#9ca3af", "#dc2626", "#1f2937"];

function yoyBadge(v){
  if(v===null||v===undefined) return '—';
  if(v>0) return `<span class="badge-up">+${v.toFixed(1)}%</span>`;
  if(v<0) return `<span class="badge-dn">${v.toFixed(1)}%</span>`;
  return `<span class="badge-neu">0.0%</span>`;
}
const tbM = document.getElementById('tbMonthly');
months.forEach((m,i)=>{
  tbM.innerHTML += `<tr><td>${m}</td><td>${pbData[i].toFixed(2)}</td><td>${epData[i].toFixed(2)}</td><td><strong>${totData[i].toFixed(2)}</strong></td><td>${yoyBadge(yoyPB[i])}</td><td>${yoyBadge(yoyEP[i])}</td><td>${yoyBadge(yoyTot[i])}</td></tr>`;
});
const tbR = document.getElementById('tbRatio');
months.forEach((m,i)=>{
  const pr=(pbData[i]/totData[i]*100).toFixed(1);
  const er=(epData[i]/totData[i]*100).toFixed(1);
  tbR.innerHTML += `<tr><td>${m}</td><td>${pbData[i].toFixed(2)}</td><td>${pr}%</td><td>${epData[i].toFixed(2)}</td><td>${er}%</td></tr>`;
});

new Chart(document.getElementById('chartAnnual'),{type:'bar',data:{labels:['1월','2월','3월','4월'],datasets:[{label:'2025 PB',data:[8.58,8.20,11.32,9.46],backgroundColor:'#374151',borderRadius:3,stack:'2025'},{label:'2025 EP',data:[2.94,3.50,3.09,2.51],backgroundColor:'#9ca3af',borderRadius:3,stack:'2025'},{label:'2026 PB',data:[9.415,6.2334,8.3452,5.5549],backgroundColor:'#1e40af',borderRadius:3,stack:'2026'},{label:'2026 EP',data:[4.0937,3.4189,4.364,3.295],backgroundColor:'#93c5fd',borderRadius:3,stack:'2026'}]},options:{plugins:{legend:{labels:{font:{size:11},boxWidth:12}}},scales:{x:{ticks:{font:{size:11}},stacked:true},y:{ticks:{font:{size:10}},stacked:true,title:{display:true,text:'억원',font:{size:10}}}}},plugins:[{id:'annualLbl',afterDraw(chart){const ctx=chart.ctx;ctx.save();ctx.font='600 10px "Noto Sans KR",sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';chart.data.datasets.forEach((ds,di)=>{const meta=chart.getDatasetMeta(di);meta.data.forEach((bar,i)=>{const h=bar.base-bar.y;if(h>18){ctx.fillStyle='#ffffff';ctx.fillText(ds.data[i].toFixed(1)+'억',bar.x,(bar.y+bar.base)/2);}});});ctx.restore();}}]});

const pbPlugin={id:'pbLabel',afterDraw(chart){const ctx=chart.ctx;ctx.save();ctx.font='600 10px "Noto Sans KR",sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillStyle='#ffffff';chart.data.datasets.forEach((ds,di)=>{const meta=chart.getDatasetMeta(di);meta.data.forEach((bar,i)=>{const h=bar.base-bar.y;if(h>18)ctx.fillText(ds.data[i].toFixed(1)+'억',bar.x,(bar.y+bar.base)/2);});});ctx.restore();}};
new Chart(document.getElementById('chartMonthly'),{type:'bar',data:{labels:months,datasets:[{label:'PB',data:pbData,backgroundColor:'#374151',borderRadius:3,stack:'a'},{label:'EP',data:epData,backgroundColor:'#9ca3af',borderRadius:3,stack:'a'}]},options:{plugins:{legend:{labels:{font:{size:11},boxWidth:12}}},scales:{x:{ticks:{font:{size:10}}},y:{ticks:{font:{size:10}},title:{display:true,text:'억원',font:{size:10}}}}},plugins:[pbPlugin]});

const yoyPlugin={id:'yoyLbl',afterDraw(chart){const ctx=chart.ctx;const meta=chart.getDatasetMeta(0);ctx.save();ctx.font='bold 10px "Noto Sans KR",sans-serif';ctx.textAlign='center';meta.data.forEach((pt,i)=>{const v=yoyTot[i];const pos=v>=0;ctx.fillStyle=pos?'#374151':'#dc2626';ctx.textBaseline=pos?'bottom':'top';ctx.fillText((pos?'+':'')+v.toFixed(1)+'%',pt.x,pos?pt.y-8:pt.y+8);});ctx.restore();}};
new Chart(document.getElementById('chartMonthlyYoY'),{type:'line',data:{labels:months,datasets:[{label:'합산 YoY(%)',data:yoyTot,borderColor:'#374151',backgroundColor:'rgba(55,65,81,0.08)',pointBackgroundColor:yoyTot.map(v=>v>=0?'#374151':'#dc2626'),pointBorderColor:yoyTot.map(v=>v>=0?'#374151':'#dc2626'),pointRadius:5,pointHoverRadius:7,tension:0.3,fill:true}]},options:{plugins:{legend:{labels:{font:{size:11},boxWidth:12}}},scales:{x:{ticks:{font:{size:10}}},y:{ticks:{font:{size:10}},title:{display:true,text:'YoY (%)',font:{size:10}}}}},plugins:[yoyPlugin]});

new Chart(document.getElementById('chartRatio'),{type:'bar',data:{labels:months,datasets:[{label:'PB(%)',data:months.map((_,i)=>+(pbData[i]/totData[i]*100).toFixed(1)),backgroundColor:'#374151',stack:'r'},{label:'EP(%)',data:months.map((_,i)=>+(epData[i]/totData[i]*100).toFixed(1)),backgroundColor:'#9ca3af',stack:'r'}]},options:{plugins:{legend:{labels:{font:{size:11},boxWidth:12}}},scales:{x:{ticks:{font:{size:10}}},y:{ticks:{font:{size:10}},max:100,title:{display:true,text:'%',font:{size:10}}}}}});

new Chart(document.getElementById('chartPB26'),{type:'bar',data:{labels:['1월','2월','3월','4월'],datasets:[{label:'25년',data:[8.58,8.20,11.32,9.47],backgroundColor:'#9ca3af',borderRadius:4},{label:'26년',data:[9.42,6.23,8.35,5.55],backgroundColor:'#374151',borderRadius:4}]},options:{plugins:{legend:{labels:{font:{size:11},boxWidth:12}}},scales:{x:{ticks:{font:{size:11}}},y:{ticks:{font:{size:10}},title:{display:true,text:'억원',font:{size:10}}}}},plugins:[{id:'pb26Lbl',afterDraw(chart){const ctx=chart.ctx;ctx.save();ctx.font='600 10px "Noto Sans KR",sans-serif';ctx.textAlign='center';ctx.textBaseline='bottom';chart.data.datasets.forEach((ds,di)=>{const meta=chart.getDatasetMeta(di);const color=di===0?'#6b7280':'#374151';ctx.fillStyle=color;meta.data.forEach((bar,i)=>{ctx.fillText(ds.data[i].toFixed(1)+'억',bar.x,bar.y-4);});});ctx.restore();}}]});

new Chart(document.getElementById('chartCatYoY'),{type:'bar',data:{labels:catNames26,datasets:[{label:'25년(억)',data:catData25,backgroundColor:'#9ca3af',borderRadius:3},{label:'26년(억)',data:catData26,backgroundColor:'#374151',borderRadius:3}]},options:{plugins:{legend:{labels:{font:{size:11},boxWidth:12}}},scales:{x:{ticks:{font:{size:11}}},y:{ticks:{font:{size:10}},title:{display:true,text:'억원',font:{size:10}}}}},plugins:[{id:'catYoYLbl',afterDraw(chart){const ctx=chart.ctx;ctx.save();ctx.font='600 10px "Noto Sans KR",sans-serif';ctx.textAlign='center';ctx.textBaseline='bottom';chart.data.datasets.forEach((ds,di)=>{const meta=chart.getDatasetMeta(di);const color=di===0?'#6b7280':'#374151';ctx.fillStyle=color;meta.data.forEach((bar,i)=>{ctx.fillText(ds.data[i].toFixed(1)+'억',bar.x,bar.y-4);});});ctx.restore();}}]});

const piePlugin={id:'pieLbl',afterDraw(chart){const ctx=chart.ctx;const meta=chart.getDatasetMeta(0);const ds=chart.data.datasets[0];const labels=chart.data.labels;ctx.save();meta.data.forEach((arc,i)=>{const mid=(arc.startAngle+arc.endAngle)/2;const r=(arc.outerRadius+arc.innerRadius)/2;const x=arc.x+Math.cos(mid)*r;const y=arc.y+Math.sin(mid)*r;const arcLen=(arc.endAngle-arc.startAngle)*r;if(arcLen>22){ctx.fillStyle='#fff';ctx.textAlign='center';ctx.font='bold 9px "Noto Sans KR",sans-serif';ctx.textBaseline='middle';ctx.fillText(labels[i],x,y-5.5);ctx.font='9px "Noto Sans KR",sans-serif';ctx.fillText(ds.data[i].toFixed(1)+'%',x,y+5.5);}});ctx.restore();}};
new Chart(document.getElementById('chartCatShare'),{type:'doughnut',data:{labels:catNames26,datasets:[{data:catShare26,backgroundColor:catColors,borderWidth:2,borderColor:'#fff'}]},options:{plugins:{legend:{display:false}},cutout:'65%'},plugins:[piePlugin]});
new Chart(document.getElementById('chartCatShare25'),{type:'doughnut',data:{labels:catNames26,datasets:[{data:catShare25,backgroundColor:catColors,borderWidth:2,borderColor:'#fff'}]},options:{plugins:{legend:{display:false}},cutout:'65%'},plugins:[piePlugin]});

const catYoYData=catNames26.map((_,i)=>catData25[i]>0?+((catData26[i]/catData25[i]-1)*100).toFixed(1):0);
const catYoYPlugin={id:'catYoYLbl',afterDraw(chart){const ctx=chart.ctx;const meta=chart.getDatasetMeta(0);ctx.save();ctx.font='bold 11px "Noto Sans KR",sans-serif';ctx.textBaseline='middle';meta.data.forEach((bar,i)=>{const v=catYoYData[i];const pos=v>=0;ctx.fillStyle=pos?'#374151':'#dc2626';ctx.textAlign=pos?'left':'right';const x=pos?bar.x+5:bar.x-5;ctx.fillText((pos?'+':'')+v.toFixed(1)+'%',x,bar.y);});ctx.restore();}};
new Chart(document.getElementById('chartCatYoYBar'),{type:'bar',data:{labels:catNames26,datasets:[{label:'YoY(%)',data:catYoYData,backgroundColor:catYoYData.map(v=>v>=0?'rgba(55,65,81,0.8)':'rgba(220,38,38,0.8)'),borderRadius:3}]},options:{indexAxis:'y',plugins:{legend:{display:false}},scales:{x:{ticks:{font:{size:10}},title:{display:true,text:'YoY (%)',font:{size:10}}},y:{ticks:{font:{size:11}}}}},plugins:[catYoYPlugin]});

function showTab(name){
  document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active'));
  document.getElementById('tab-'+name)?.classList.add('active');
  document.querySelectorAll('.tab-btn').forEach(btn=>{if(btn.textContent.includes(name))btn.classList.add('active');});
}
const sects=document.querySelectorAll('section[id],div[id]');
const navAs=document.querySelectorAll('nav a');
window.addEventListener('scroll',()=>{let cur='';sects.forEach(s=>{if(window.scrollY>=s.offsetTop-120)cur=s.id;});navAs.forEach(a=>{a.classList.remove('active');if(a.getAttribute('href')==='#'+cur)a.classList.add('active');});},{passive:true});
</script>

